# ---- Supabase ----
# Project URL, np. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon (public) key — uzywany TYLKO do subskrypcji Broadcast w przegladarce
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERWER ONLY (Server Actions + webhook). Omija RLS. Nigdy nie eksponuj.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (Test Mode) ----
STRIPE_SECRET_KEY=sk_test_...
# Sekret z `stripe listen` lub z dashboardu webhooka
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- App ----
# Pelny origin aplikacji, uzywany do success_url / cancel_url Stripe Checkout
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Baner demo (karta testowa + dane logowania personelu). 1 = wlaczony, puste = ukryty.
NEXT_PUBLIC_DEMO=
